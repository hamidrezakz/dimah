{
  "name": "@dimah/fa-utils",
  "version": "0.3.3",
  "description": "Simple Persian date and number formatting helpers using built-in Intl APIs",
  "keywords": [
    "persian",
    "farsi",
    "intl",
    "date",
    "number-formatting"
  ],
  "author": "Hamidrezakz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamidrezakz/dimah.git",
    "directory": "packages/fa-utils"
  },
  "homepage": "https://github.com/hamidrezakz/dimah/tree/master/packages/fa-utils",
  "bugs": {
    "url": "https://github.com/hamidrezakz/dimah/issues"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "check-types": "tsc --noEmit"
