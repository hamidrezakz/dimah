{
  "name": "@better-s3/ui",
  "version": "0.1.0",
  "description": "Pre-built React UI components for S3 file upload, download, and delete",
  "keywords": [
    "s3",
    "react",
    "ui",
    "upload",
    "download",
    "file-upload",
    "components"
  ],
  "author": "Hamidrezakz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamidrezakz/dimah.git",
    "directory": "packages/better-s3-ui"
  },
  "homepage": "https://github.com/hamidrezakz/dimah/tree/master/packages/better-s3-ui",
  "bugs": {
    "url": "https://github.com/hamidrezakz/dimah/issues"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --emitDeclarationOnly",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@better-s3/core": "workspace:*",
    "@better-s3/react": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "@base-ui/react": ">=1.0.0",
    "class-variance-authority": ">=0.7.0",
    "clsx": ">=2.0.0",
    "tailwind-merge": ">=2.0.0",
    "lucide-react": ">=0.400.0",
    "sonner": ">=1.0.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@types/react": "^19.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.500.0",
    "react": "^19.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
